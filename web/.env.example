# Template only. Copy to .env.local and fill in real values.
# NEVER commit real credentials to this file — it is tracked by git.

# --- App ---
APP_NAME=BIIDP API
ENVIRONMENT=development
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-bytes
ACCESS_TOKEN_MINUTES=60

# --- Database ---
# Any of DATABASE_URL / POSTGRES_URL / POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING works.
# Define DATABASE_URL exactly once: a duplicate key silently overrides the first.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biidp

# --- Firebase (server-side ID token verification for /api/v1/auth/firebase) ---
# Optional when NEXT_PUBLIC_FIREBASE_PROJECT_ID below is set to the same project.
FIREBASE_PROJECT_ID=

# --- Firebase (browser SDK: Google sign-in). Public by design, but keep the
# real project's values out of version control. ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Object storage (Cloudflare R2) ---
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Local storage fallback (development only) ---
LOCAL_STORAGE_PATH=./local-storage
LOCAL_STORAGE_BASE_URL=http://localhost:3000
MAX_UPLOAD_BYTES=524288000
