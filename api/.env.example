# Template only. Copy to .env and fill in real values.
# NEVER commit real credentials to this file — it is tracked by git.

APP_NAME=BIIDP API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
WEB_ORIGINS=["http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/biidp

# --- Auth ---
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-bytes
ACCESS_TOKEN_MINUTES=60
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=

# --- Firebase (server-side ID token verification) ---
FIREBASE_PROJECT_ID=

# --- Object storage (Cloudflare R2) ---
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Local storage fallback (development only) ---
LOCAL_STORAGE_PATH=./local-storage
LOCAL_STORAGE_BASE_URL=http://localhost:8000
MAX_UPLOAD_BYTES=524288000
